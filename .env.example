# Supabase — create a project at https://supabase.com
# Quick setup: paste supabase/full-setup.sql into the SQL editor (or run `bun run supabase:apply`
# with SUPABASE_DB_PASSWORD set). Then `bun run supabase:verify` to confirm tables exist.
# Promote yourself: update public.profiles set role = 'admin' where id = '<your-user-uuid>';
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-jwt-key
# Optional newer publishable key (used if anon JWT is not set)
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Optional: enable GitHub/Google OAuth in Supabase → Authentication → Providers
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# For `bun run supabase:apply` / `bun run supabase:seed` (never prefix with VITE_)
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email — serverless/edge endpoint (see api/email.ts and src/lib/email-handler.ts)
# VITE_EMAIL_ENDPOINT=https://your-app.vercel.app/api/email
# VITE_EMAIL_API_SECRET=random-secret-matching-EMAIL_API_SECRET-on-server

# Server-side only (Vercel/Cloudflare secrets — never prefix with VITE_)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_API_SECRET=random-secret-required-in-production
# EMAIL_FROM=The Bu1ld <hello@thebu1ld.com>
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# EMAIL_ALLOW_UNAUTH_DEV=true  # local dev only — never set in production

# Local-only fallback (do not ship client Resend keys in production)
# VITE_RESEND_API_KEY=re_xxxxxxxx
