# Supabase — create a project at https://supabase.com
# 1. Run supabase/schema.sql in the SQL editor
# 2. Run supabase/phase2.sql for events, papers, newsletter, reading progress
# 3. Run supabase/phase3.sql for projects, applications, jobs, lead verification
# 4. Run supabase/phase4.sql for notifications, saved items, admin member reads
# 5. Run supabase/phase5.sql for announcements and project discord links
# 6. Set your profile role to 'admin' in the profiles table to access /admin
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional — transactional email via Resend (welcome, application updates)
# VITE_RESEND_API_KEY=re_xxxxxxxx
